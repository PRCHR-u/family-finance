```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.ENV/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
.coverage
htmlcov/
coverage/

# Build artifacts
dist/
build/
*.egg-info/
```