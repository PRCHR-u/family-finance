```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.out

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Build outputs
dist/
build/
target/

# Python cache
.mypy_cache/
.pytest_cache/
```